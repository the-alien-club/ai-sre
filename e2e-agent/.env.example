# GitLab Webhook Channel
GITLAB_WEBHOOK_PORT=8791
GITLAB_WEBHOOK_HOST=0.0.0.0
# Shared secret matching the "Secret token" field in the GitLab webhook config.
# GitLab sends it in the X-Gitlab-Token header.
GITLAB_WEBHOOK_TOKEN=your-shared-secret-here

# GitLab API access (read-only token to fetch MR diffs, pipeline status, etc.)
GITLAB_TOKEN=glpat-your-readonly-token
GITLAB_BASE_URL=https://gitlab.com

# Slack QA Channel
# Create a separate Slack app from the SRE one (or reuse — but use a different bot user).
# Enable Socket Mode, add connections:write scope to App-Level Token.
# Bot Token Scopes: chat:write, files:write, im:read, im:write, im:history, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
QA_OWNER_SLACK_ID=U01ABCDEF
# Optional: a channel ID for non-DM updates (daily summaries, regression status)
QA_CHANNEL_ID=C0123456789

# Escalation Timing (milliseconds)
ESCALATION_INTERVAL_MS=600000
DEV_ESCALATION_INTERVAL_MS=3600000

# Test Run Configuration
PLAYWRIGHT_BROWSERS=chromium
PLAYWRIGHT_HEADLESS=true
TEST_ARTIFACT_DIR=./data/artifacts

# Base URLs for environments under test (override per MR if the pipeline ships a preview URL)
DEV_BASE_URL=https://dev.example.com
STAGING_BASE_URL=https://staging.example.com

# SigNoz MCP (used during deep-dive to query logs, traces, metrics for affected services)
SIGNOZ_URL=https://your-signoz-instance.signoz.cloud
SIGNOZ_TOKEN=your-signoz-api-key

# Repos directory — read-only clones of platform repos used during deep-dive.
# Same convention as the SRE agent. Mirror or share the SRE VM's ~/repos.
REPOS_DIR=/home/user/repos

# Kubectl context names — populated by the VM's kubeconfig.
# Used in deep-dive to look at pod state for the failing service.
KUBECTL_PLATFORM_DEV=platform-dev
KUBECTL_PLATFORM_PROD=platform-prod
KUBECTL_DATA_DEV=data-cluster-dev
KUBECTL_DATA_BIORXIV=data-cluster-biorxiv
KUBECTL_DATA_ALIEN=data-cluster-alien-hosted
