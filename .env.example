# SigNoz Webhook Channel
SIGNOZ_WEBHOOK_PORT=8788
SIGNOZ_WEBHOOK_HOST=0.0.0.0
SIGNOZ_WEBHOOK_TOKEN=your-shared-secret-here

# Trivy Webhook Channel (security findings from Trivy operator)
TRIVY_WEBHOOK_PORT=8790
TRIVY_WEBHOOK_HOST=0.0.0.0
TRIVY_WEBHOOK_TOKEN=your-trivy-shared-secret

# Slack SRE Channel
# Create a Slack app at https://api.slack.com/apps
# Enable Socket Mode, add connections:write scope to App-Level Token
# Bot Token Scopes: chat:write, im:read, im:write, im:history, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
CTO_SLACK_ID=U01ABCDEF

# Escalation Timing (milliseconds)
ESCALATION_INTERVAL_MS=600000
DEV_ESCALATION_INTERVAL_MS=3600000
